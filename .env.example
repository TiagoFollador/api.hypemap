# Database — PostgreSQL with PostGIS
DATABASE_URL=postgresql://hypemap:hypemap@localhost:5432/hypemap?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Paste the full PEM content (with newlines escaped as \n)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Server
PORT=3000
NODE_ENV=development

# Data retention (days)
LOCATION_EVENT_RETENTION_DAYS=30
