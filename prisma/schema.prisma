generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  handle       String   @unique @db.VarChar(32)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  liveLocation  LiveLocation?
  friendEdges   FriendEdge[]  @relation("UserFriendEdges")
  friendOf      FriendEdge[]  @relation("FriendEdges")
  consentLogs   ConsentLog[]
  squadMembers  SquadMember[]

  @@map("app_user")
}

// Spatial columns (geom, geog) are added by 001_init_postgis.sql via ALTER TABLE.
// All spatial reads/writes must use raw pg.Pool queries — never Prisma for geometry.
model LiveLocation {
  userId    String   @id @map("user_id") @db.Uuid
  accuracyM Float?   @map("accuracy_m") @db.Real
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("live_location")
}

model FriendEdge {
  userId    String   @map("user_id") @db.Uuid
  friendId  String   @map("friend_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user   User @relation("UserFriendEdges", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendEdges", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@map("friend_edge")
}

model ConsentLog {
  id        BigInt   @id @default(autoincrement())
  userId    String   @map("user_id") @db.Uuid
  action    String   @db.Text
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("consent_log")
}

model Squad {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.Text
  campusId   String?  @map("campus_id") @db.Text
  inviteCode String   @unique @map("invite_code") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  members SquadMember[]

  @@map("squad")
}

model SquadMember {
  squadId  String   @map("squad_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz

  squad Squad @relation(fields: [squadId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([squadId, userId])
  @@map("squad_member")
}
